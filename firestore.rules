rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite leitura e escrita nas coleções para desenvolvimento
    match /erp_mappings/{mappingId} {
      allow read, write: if true;
    }
    
    match /cubo_metrics/{metricId} {
      allow read, write: if true;
    }
    
    // Regra padrão: bloqueia tudo o que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}