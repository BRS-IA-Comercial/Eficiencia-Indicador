
{
  "entities": {
    "ErpMapping": {
      "title": "Mapeamento ERP",
      "description": "Mapeia um conglomerado para um ou mais códigos ERP mãe.",
      "type": "object",
      "properties": {
        "conglomerado": {
          "type": "string",
          "description": "Nome do conglomerado (Coluna C)"
        },
        "erpMaeCodes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Lista de códigos ERP mãe (Coluna E)"
        },
        "importedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data e hora da importação"
        }
      },
      "required": ["conglomerado", "erpMaeCodes", "importedAt"]
    },
    "CuboMetric": {
      "title": "Métrica de Produtividade (Cubo)",
      "description": "Dados de produtividade e ganhos financeiros extraídos dos cubos SQL.",
      "type": "object",
      "properties": {
        "executivo": { "type": "string" },
        "cliente": { "type": "string" },
        "conglomerado": { "type": "string" },
        "mes": { "type": "string" },
        "qtdIA": { "type": "number" },
        "qtdTotal": { "type": "number" },
        "hoursSaved": { "type": "number" },
        "fte": { "type": "number" },
        "financialGain": { "type": "number" },
        "grupo": { "type": "string" },
        "origem": { "type": "string" },
        "fase": { "type": "string" },
        "dataImpl": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/erp_mappings/{mappingId}": {
      "schema": "ErpMapping",
      "description": "Coleção de mapeamentos de ERP importados via Excel."
    },
    "/cubo_metrics/{metricId}": {
      "schema": "CuboMetric",
      "description": "Métricas de ROI e produtividade sincronizadas dos cubos internos."
    }
  }
}
